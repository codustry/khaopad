# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here-change-me
BETTER_AUTH_URL=http://cms.khaopad.local:5173

# GitHub content mode (only needed when CONTENT_MODE = "github")
GITHUB_TOKEN=ghp_your_personal_access_token

# Cloudflare (for wrangler CLI, not needed in Workers runtime)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-account-id
